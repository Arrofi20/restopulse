# ============================================
# RestoPulse Environment Configuration
# ============================================
# Copy this file to .env and fill in real values.
# DO NOT commit .env to version control.

# --------------------------------------------
# Database
# --------------------------------------------
# DB_PROVIDER determines which Prisma schema file is used.
# Valid values: sqlite | postgresql
# Local dev uses sqlite; production on Render uses postgresql.
DB_PROVIDER=sqlite

# DATABASE_URL is the connection string for the database.
# SQLite (local development):
DATABASE_URL=file:./prisma/dev.db
# PostgreSQL (production on Render):
# DATABASE_URL=postgresql://user:password@host:port/database

# --------------------------------------------
# Auth
# --------------------------------------------
# JWT_SECRET must be a strong random string (≥32 characters).
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-me-to-a-random-32-char-string

# --------------------------------------------
# CORS
# --------------------------------------------
# CORS_ORIGIN is the URL of the frontend app.
# Local development:
CORS_ORIGIN=http://localhost:5173
# Production: set this to your deployed frontend Static Site URL on Render.

# --------------------------------------------
# Server
# --------------------------------------------
# PORT is the port the Express API listens on.
PORT=3000

# --------------------------------------------
# Frontend Build-time
# --------------------------------------------
# VITE_API_BASE_URL is the base URL for API calls from the frontend.
# For split deploy (frontend on Render Static Site, backend on Render Web Service),
# set this to the backend's public URL (e.g., https://restopulse-api.onrender.com/api).
# For local development with Vite proxy, use /api.
VITE_API_BASE_URL=/api

# --------------------------------------------
# AI (Google Gemini)
# --------------------------------------------
# GEMINI_API_KEY is required for the AI Business Summary feature (FR-011).
# If not set, the dashboard will show a mock summary instead of crashing.
# This key is ONLY used server-side and is NEVER exposed to the frontend.
# Get your API key from: https://aistudio.google.com/app/apikey
#
# Model used: gemini-2.5-flash (free tier, 15 requests/min)
# Timeout: 15 seconds per request
# If the API is unavailable, over quota, or the key is invalid, the
# system automatically falls back to a mock summary. No other features
# are affected.
GEMINI_API_KEY=

# ============================================
# Production Migration Command
# ============================================
# Run the following on Render (or any production environment) after setting
# DB_PROVIDER=postgresql and DATABASE_URL to your PostgreSQL connection string:
#
#   npm run db:migrate:prod
#
# This applies pending migrations to the production PostgreSQL database using
# prisma/schema.postgresql.prisma.
