{
  "name": "restopulse",
  "version": "1.1.0",
  "description": "RestoPulse — Dashboard analitik dan laporan digital untuk pemilik restoran",
  "main": "index.js",
  "type": "commonjs",
  "workspaces": [
    "frontend"
  ],
  "scripts": {
    "test:api": "npx vitest run --config vitest.config.ts",
    "test:api:watch": "npx vitest --config vitest.config.ts",
    "postinstall": "npx prisma generate",
    "predev": "node scripts/setup-env.js && npx prisma migrate deploy",
    "dev": "concurrently \"npm:dev:backend\" \"npm:dev:frontend\"",
    "dev:backend": "npx nodemon src/server.ts",
    "dev:frontend": "npm -w frontend run dev",
    "start": "node dist/server.js",
    "build": "npx tsc",
    "db:migrate": "npx prisma migrate dev",
    "db:migrate:prod": "npx prisma migrate deploy --schema=prisma/schema.postgresql.prisma",
    "db:generate": "npx prisma generate",
    "db:seed": "npx ts-node scripts/seed.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@prisma/client": "^7.8.0",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "jsonwebtoken": "^9.0.3",
    "prisma": "^7.8.0",
    "prisma-adapter-sqlite": "^1.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^26.0.1",
    "@types/supertest": "^7.2.0",
    "concurrently": "^9.2.0",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "allowScripts": {
    "bcrypt@6.0.0": true,
    "prisma@7.8.0": true,
    "@prisma/engines@7.8.0": true
  }
}
